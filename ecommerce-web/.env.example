# Firebase — required for "Talk to Agent" (WebRTC + Firestore signaling, no Jitsi).
# 1) Create a project: https://console.firebase.google.com → Web app config
# 2) Authentication → click "Get started" once (required). Then Sign-in method → enable Anonymous.
#    Error auth/configuration-not-found = Auth never enabled, or Identity Toolkit API disabled in GCP.
# 3) Firestore → create database → rules must allow signed-in users to read/write:
#    match /webrtc_calls/{roomId} { allow read, write: if request.auth != null; }
#    match /agent_calls/{id} { allow create: if request.auth != null; allow read: if request.auth != null; }

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — Google Analytics / Firebase Analytics (measurementId from Firebase console)
VITE_FIREBASE_MEASUREMENT_ID=

# WebRTC — if both sides only see "You" and remote is black, the network blocks direct P2P.
# The app defaults include Metered Open Relay TURN. For production, use your own TURN (Twilio, Metered, etc.).
# Optional override: JSON array of RTCIceServer objects, replaces defaults entirely, e.g.:
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:YOUR_TURN:3478","username":"u","credential":"p"}]

VITE_WEBRTC_ICE_SERVERS=
